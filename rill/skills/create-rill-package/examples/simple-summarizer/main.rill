# Simple text summarizer
# Extensions: ai (Anthropic LLM), prompt (prompt-md)

use<ext:ai> => $ai
use<ext:prompt> => $prompt

# Entry point: takes text input, returns bullet-point summary
^("Summarize input text into bullet points") |^("Text to summarize") input: string| {

  # Validate input
  $input -> assert !.empty "Input cannot be empty"

  "Summarizing {$input -> .len} characters..." -> log

  # Build messages from externalized prompt and call LLM
  # (prompt-md list-mode prompts feed directly into message() in rill-ext 0.19.6)
  $prompt.summarize($input) => $messages
  $ai.message($messages)() => $result

  # Return structured result; messages is parts-shaped history
  dict[
    summary: $result.messages[-1].parts[0].text,
    usage: $result.usage,
  ]

} => $summarize
