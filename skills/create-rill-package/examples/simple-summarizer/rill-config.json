{
  "name": "simple-summarizer",
  "version": "0.1.0",
  "main": "main.rill:summarize",
  "extensions": {
    "mounts": {
      "ai": "@rcrsr/rill-ext-anthropic",
      "prompt": "@rcrsr/rill-ext-prompt-md"
    },
    "config": {
      "ai": {
        "api_key": "${ANTHROPIC_API_KEY}",
        "model": "claude-sonnet-4-5-20250929",
        "max_tokens": 1024
      },
      "prompt": {
        "basePath": "./prompts"
      }
    }
  }
}
